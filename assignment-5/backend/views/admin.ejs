<%- include('partials/header') %>

<section class="destinations" style="padding-top: 150px;">
    <h2 class="section-title">Admin Dashboard</h2>
    <div style="max-width: 1000px; margin: 0 auto; text-align: left;">
        <h3 style="margin-bottom: 20px; color: var(--primary-color);">Inquiries Received</h3>
        <div style="background: var(--glass-bg); padding: 30px; border-radius: 20px; border: 1px solid var(--glass-border); overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 1px solid var(--glass-border); color: var(--text-muted); text-transform: uppercase; font-size: 12px;">
                        <th style="padding: 15px; text-align: left;">Name</th>
                        <th style="padding: 15px; text-align: left;">Email</th>
                        <th style="padding: 15px; text-align: left;">Destination</th>
                        <th style="padding: 15px; text-align: left;">Message</th>
                        <th style="padding: 15px; text-align: right;">Date</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (inquiries.length > 0) { %>
                        <% inquiries.forEach(inq => { %>
                            <tr style="border-bottom: 1px solid var(--glass-border);">
                                <td style="padding: 15px;"><%= inq.name %></td>
                                <td style="padding: 15px;"><%= inq.email %></td>
                                <td style="padding: 15px; color: var(--accent-color);"><%= inq.destination %></td>
                                <td style="padding: 15px; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= inq.message %></td>
                                <td style="padding: 15px; text-align: right; color: var(--text-muted);"><%= inq.date.toDateString() %></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" style="padding: 30px; text-align: center; color: var(--text-muted);">No inquiries yet.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <h3 style="margin: 50px 0 20px; color: var(--primary-color);">Manage Destinations</h3>
        <div class="destination-grid">
            <% destinations.forEach(dest => { %>
                <div class="dest-card" style="padding: 20px; display: flex; align-items: center; gap: 20px;">
                    <img src="<%= dest.image %>" style="width: 60px; height: 60px; border-radius: 50%; object-fit: cover;">
                    <div style="flex: 1;">
                        <span style="font-weight: 700;"><%= dest.name %></span>
                        <div style="font-size: 12px; color: var(--text-muted);">Price: $<%= dest.price %></div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
