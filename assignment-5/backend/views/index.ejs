<%- include('partials/header') %>

<!-- Hero -->
<header class="hero">
    <p data-lucide="compass" style="color: var(--primary-color); margin-bottom: 20px;"></p>
    <h1>Escape Local. Live Global.</h1>
    <p>Luxury Curated Experiences Worldwide</p>
    <a href="#destinations" class="cta-button">Browse Collections</a>
</header>

<!-- Destinations -->
<section id="destinations" class="destinations">
    <h2 class="section-title">Curated Destinations</h2>
    <div class="destination-grid">
        <% featured.forEach(dest => { %>
            <div class="dest-card">
                <img src="<%= dest.image %>" alt="<%= dest.name %>" class="dest-image">
                <div class="dest-content">
                    <h3><%= dest.name %></h3>
                    <p><%= dest.description %></p>
                    <div class="dest-footer">
                        <span class="price">$<%= dest.price %></span>
                        <a href="#contact" class="cta-button" style="padding: 10px 25px; font-size: 12px; border-radius: 8px;">Book Now</a>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</section>

<!-- Inquiry Section -->
<section id="contact" class="contact-section">
    <h2 class="section-title">Plan Your Journey</h2>
    <div class="contact-container">
        <form action="/inquiry" method="POST">
            <div class="form-group">
                <label for="name">Full Name</label>
                <input type="text" id="name" name="name" required placeholder="Enter your full name">
            </div>
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" required placeholder="Enter your email">
            </div>
            <div class="form-group">
                <label for="destination">Interested Destination</label>
                <select id="destination" name="destination" required>
                    <option value="" disabled selected>Select a destination</option>
                    <% featured.forEach(dest => { %>
                        <option value="<%= dest.name %>"><%= dest.name %></option>
                    <% }) %>
                    <option value="Custom">Custom / Other</option>
                </select>
            </div>
            <div class="form-group">
                <label for="message">Travel Vision</label>
                <textarea id="message" name="message" rows="5" placeholder="Tell us about your dream trip..."></textarea>
            </div>
            <button type="submit" class="submit-btn" style="background: linear-gradient(45deg, var(--primary-color), var(--accent-color)); color: #000;">Send Inquiry</button>
        </form>
    </div>
</section>

<%- include('partials/footer') %>
